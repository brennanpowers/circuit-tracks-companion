---
import controls from '../data/panel-controls.json';
import PanelSVG from './PanelSVG.astro';
import { PANEL } from '../data/panel-geometry';
import { withBase } from '../lib/url';

const elementLabels = Object.fromEntries(
  PANEL.map((el) => [el.id, el.label.replace('\n', ' ')]),
);
---

<section class="panel-map rounded-xl border border-border bg-surface p-4 sm:p-6 no-print">
  <h2 class="font-semibold text-lg">Interactive panel map</h2>
  <p class="text-sm text-muted mt-1 mb-4">
    Laid out 1-to-1 with the device (from the manual's Top View). Tap, hover, or Tab to any
    control.
  </p>

  <PanelSVG interactive={true} labels={true} />

  <div id="panel-detail" class="mt-4 rounded-lg border border-border bg-surface-2 p-4 text-sm" hidden>
    <h3 class="font-semibold" id="panel-detail-title"></h3>
    <p class="mt-1" id="panel-detail-short"></p>
    <dl class="mt-2 space-y-1" id="panel-detail-views"></dl>
    <p class="mt-2 text-muted" id="panel-detail-shift"></p>
    <a class="mt-2 inline-block text-accent underline" id="panel-detail-link" href="#">Full detail in the reference →</a>
  </div>
</section>

<script define:vars={{ controls, elementLabels, refBase: withBase('reference/') }}>
  const detail = document.getElementById('panel-detail');
  const els = {
    title: document.getElementById('panel-detail-title'),
    short: document.getElementById('panel-detail-short'),
    views: document.getElementById('panel-detail-views'),
    shift: document.getElementById('panel-detail-shift'),
    link: document.getElementById('panel-detail-link'),
  };
  const byId = Object.fromEntries(controls.map((c) => [c.id, c]));

  function show(controlId, elementId) {
    const c = byId[controlId];
    if (!c) return;
    document.querySelectorAll('.panel-map .pnl-el').forEach((h) => h.removeAttribute('data-active'));
    document
      .querySelector(`.panel-map .pnl-el[data-element="${elementId}"]`)
      ?.setAttribute('data-active', 'true');
    // Prefix the element name only for grouped controls (several elements share
    // one card); per-element cards (each macro, each button) carry full labels.
    const GROUPED = new Set(['tracks', 'arrows']);
    const elementLabel = elementLabels[elementId];
    els.title.textContent =
      GROUPED.has(c.id) && elementLabel && elementLabel !== c.label
        ? `${elementLabel} — ${c.label}`
        : c.label;
    els.short.textContent = c.short;
    els.views.innerHTML = Object.entries(c.views ?? {})
      .map(
        ([k, v]) =>
          `<div><dt class="inline font-medium">${k}:</dt> <dd class="inline text-muted">${v}</dd></div>`,
      )
      .join('');
    els.shift.textContent = c.shift ?? '';
    els.shift.hidden = !c.shift;
    els.link.href = `${refBase}${c.ref}/`;
    detail.hidden = false;
  }

  document.querySelectorAll('.panel-map .pnl-el').forEach((h) => {
    const handler = () => show(h.dataset.control, h.dataset.element);
    h.addEventListener('click', handler);
    h.addEventListener('focus', handler);
    h.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        handler();
      }
    });
  });
</script>
