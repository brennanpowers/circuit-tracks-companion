---
import controls from '../data/panel-controls.json';
import { withBase } from '../lib/url';

/** Schematic hotspot geometry, keyed by control id. Deliberately abstract —
 *  evokes the top panel's zones without reproducing Novation's trade dress. */
const HOTSPOTS: Record<string, { x: number; y: number; w: number; h: number; rx?: number }> = {
  volume: { x: 10, y: 8, w: 40, h: 40, rx: 20 },
  macros: { x: 70, y: 8, w: 300, h: 40, rx: 8 },
  filter: { x: 390, y: 4, w: 48, h: 48, rx: 24 },
  tempo: { x: 458, y: 8, w: 60, h: 18, rx: 4 },
  record: { x: 458, y: 30, w: 28, h: 18, rx: 4 },
  play: { x: 490, y: 30, w: 28, h: 18, rx: 4 },
  note: { x: 10, y: 66, w: 44, h: 20, rx: 4 },
  velocity: { x: 10, y: 90, w: 44, h: 20, rx: 4 },
  gate: { x: 10, y: 114, w: 44, h: 20, rx: 4 },
  "pattern-settings": { x: 10, y: 138, w: 44, h: 20, rx: 4 },
  grid: { x: 70, y: 62, w: 300, h: 128, rx: 8 },
  arrows: { x: 390, y: 62, w: 24, h: 52, rx: 4 },
  scales: { x: 390, y: 122, w: 58, h: 18, rx: 4 },
  preset: { x: 390, y: 144, w: 58, h: 18, rx: 4 },
  "step-page": { x: 390, y: 166, w: 58, h: 18, rx: 4 },
  patterns: { x: 458, y: 122, w: 60, h: 18, rx: 4 },
  mixer: { x: 458, y: 144, w: 60, h: 18, rx: 4 },
  fx: { x: 458, y: 166, w: 60, h: 18, rx: 4 },
  tracks: { x: 70, y: 200, w: 300, h: 22, rx: 4 },
  clear: { x: 390, y: 200, w: 28, h: 22, rx: 4 },
  duplicate: { x: 422, y: 200, w: 28, h: 22, rx: 4 },
  save: { x: 458, y: 200, w: 28, h: 22, rx: 4 },
  projects: { x: 490, y: 200, w: 28, h: 22, rx: 4 },
  shift: { x: 10, y: 166, w: 44, h: 20, rx: 4 },
};
const byId = Object.fromEntries(controls.map((c) => [c.id, c]));
---

<section class="panel-map rounded-xl border border-border bg-surface p-4 sm:p-6 no-print">
  <h2 class="font-semibold text-lg">Interactive panel map</h2>
  <p class="text-sm text-muted mt-1 mb-4">
    Tap or focus any zone — schematic, not to scale. Keyboard: Tab between zones.
  </p>

  <svg viewBox="0 0 528 232" role="group" aria-label="Circuit Tracks panel schematic" class="w-full h-auto select-none">
    {
      Object.entries(HOTSPOTS).map(([id, g]) => (
        <rect
          class="hotspot"
          data-control={id}
          x={g.x} y={g.y} width={g.w} height={g.h} rx={g.rx ?? 4}
          tabindex="0"
          role="button"
          aria-label={byId[id]?.label ?? id}
        />
      ))
    }
    {/* grid dots to suggest 4x8 pads */}
    {
      Array.from({ length: 32 }, (_, i) => (
        <circle
          cx={70 + 22 + (i % 8) * 37}
          cy={62 + 18 + Math.floor(i / 8) * 31}
          r="6"
          class="pad-dot"
        />
      ))
    }
  </svg>

  <div id="panel-detail" class="mt-4 rounded-lg border border-border bg-surface-2 p-4 text-sm" hidden>
    <h3 class="font-semibold" id="panel-detail-title"></h3>
    <p class="mt-1" id="panel-detail-short"></p>
    <dl class="mt-2 space-y-1" id="panel-detail-views"></dl>
    <p class="mt-2 text-muted" id="panel-detail-shift"></p>
    <a class="mt-2 inline-block text-accent underline" id="panel-detail-link" href="#">Full detail in the reference →</a>
  </div>
</section>

<style>
  .hotspot {
    fill: var(--surface-2);
    stroke: var(--border);
    stroke-width: 1;
    cursor: pointer;
    transition: fill 120ms ease;
  }
  .hotspot:hover,
  .hotspot:focus-visible,
  .hotspot[data-active='true'] {
    fill: color-mix(in srgb, var(--accent) 30%, var(--surface-2));
    stroke: var(--accent);
    outline: none;
  }
  .pad-dot {
    fill: var(--border);
    pointer-events: none;
  }
</style>

<script define:vars={{ controls, refBase: withBase('reference/') }}>
  const detail = document.getElementById('panel-detail');
  const els = {
    title: document.getElementById('panel-detail-title'),
    short: document.getElementById('panel-detail-short'),
    views: document.getElementById('panel-detail-views'),
    shift: document.getElementById('panel-detail-shift'),
    link: document.getElementById('panel-detail-link'),
  };
  const byId = Object.fromEntries(controls.map((c) => [c.id, c]));

  function show(id) {
    const c = byId[id];
    if (!c) return;
    document.querySelectorAll('.hotspot').forEach((h) => h.removeAttribute('data-active'));
    document.querySelector(`.hotspot[data-control="${id}"]`)?.setAttribute('data-active', 'true');
    els.title.textContent = c.label;
    els.short.textContent = c.short;
    els.views.innerHTML = Object.entries(c.views ?? {})
      .map(([k, v]) => `<div><dt class="inline font-medium">${k}:</dt> <dd class="inline text-muted">${v}</dd></div>`)
      .join('');
    els.shift.textContent = c.shift ?? '';
    els.shift.hidden = !c.shift;
    els.link.href = `${refBase}${c.ref}/`;
    detail.hidden = false;
  }

  document.querySelectorAll('.hotspot').forEach((h) => {
    const id = h.dataset.control;
    h.addEventListener('click', () => show(id));
    h.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        show(id);
      }
    });
    h.addEventListener('focus', () => show(id));
  });
</script>
