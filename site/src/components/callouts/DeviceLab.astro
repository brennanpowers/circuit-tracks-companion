---
import Callout from './Callout.astro';

interface Props {
  /** open-questions item this lab settles, e.g. "master-compressor-location" */
  issue: string;
}
const { issue } = Astro.props;
---

<Callout label="Device lab" color="--track-yellow" icon="flask">
  <slot />
  <p class="mt-2 text-sm text-muted" data-issue={issue}>
    Whatever you find — <a class="underline" href={`https://github.com/brennanpowers/circuit-tracks-companion/issues/new?title=Device+Lab:+${issue}`}>tell the project</a>.
    This experiment settles an open question in the research behind this site.
  </p>
</Callout>
