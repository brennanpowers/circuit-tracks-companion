---
import { withBase } from '../lib/url';
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';

const nav = [
  { label: 'Start Here', href: withBase('course/start-here/01-meet-the-device/') },
  { label: 'Course', href: withBase('course/') },
  { label: 'Reference', href: withBase('reference/') },
  { label: 'Cheat Sheet', href: withBase('cheat-sheet/') },
  { label: 'Resources', href: withBase('resources/') },
];
const current = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/90 backdrop-blur no-print">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center gap-4">
    <a href={withBase('')} class="flex items-center gap-2 font-bold tracking-tight shrink-0">
      <span aria-hidden="true" class="grid grid-cols-2 gap-0.5">
        <span class="w-2 h-2 rounded-[2px] bg-track-violet"></span>
        <span class="w-2 h-2 rounded-[2px] bg-track-green"></span>
        <span class="w-2 h-2 rounded-[2px] bg-track-orange"></span>
        <span class="w-2 h-2 rounded-[2px] bg-track-aqua"></span>
      </span>
      <span>Circuit Tracks Companion</span>
    </a>

    <nav class="hidden md:flex items-center gap-1 text-sm ml-auto" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={current.startsWith(item.href) ? 'page' : undefined}
            class="px-3 py-1.5 rounded-md hover:bg-surface-2 aria-[current=page]:bg-surface-2 aria-[current=page]:text-accent"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1 md:ml-2 ml-auto">
      <Search />
      <ThemeToggle />
      <details class="md:hidden relative">
        <summary
          class="list-none cursor-pointer p-2 rounded-md hover:bg-surface-2"
          aria-label="Menu"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        </summary>
        <nav
          class="absolute right-0 top-11 w-52 rounded-lg border border-border bg-surface shadow-xl p-2 flex flex-col"
          aria-label="Mobile"
        >
          {nav.map((item) => <a href={item.href} class="px-3 py-2 rounded-md hover:bg-surface-2">{item.label}</a>)}
        </nav>
      </details>
    </div>
  </div>
</header>
