---
import { withBase } from '../lib/url';
import ProgressBar from './ProgressBar.astro';
import type { CourseProject } from '../data/projects';

interface Props {
  project: CourseProject;
  lessonIds: string[];
  firstLessonHref: string | undefined;
}
const { project, lessonIds, firstLessonHref } = Astro.props;
const href = firstLessonHref ?? withBase('course/');
---

<a
  href={href}
  class="group rounded-xl border border-border bg-surface p-5 flex flex-col gap-3 hover:border-accent transition-colors"
  style={`border-top: 3px solid var(${project.color})`}
>
  <div class="flex items-baseline gap-3">
    <span class="text-2xl font-bold font-mono" style={`color: var(${project.color})`}>
      {project.number}
    </span>
    <h2 class="text-lg font-semibold group-hover:text-accent">{project.title}</h2>
  </div>
  <p class="text-sm text-muted flex-1">{project.tagline}</p>
  <p class="text-sm"><span class="text-muted">You'll finish with:</span> {project.deliverable}</p>
  <ProgressBar ids={lessonIds} color={project.color} />
</a>
