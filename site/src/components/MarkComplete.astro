---
interface Props {
  lessonId: string;
}
const { lessonId } = Astro.props;
---

<button
  type="button"
  class="mark-complete no-print inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium hover:border-accent"
  data-lesson-id={lessonId}
  aria-pressed="false"
>
  <span
    class="box grid place-items-center w-5 h-5 rounded border border-border text-bg"
    aria-hidden="true"
  >
    <svg class="check hidden" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
  </span>
  <span class="label">Mark lesson complete</span>
</button>

<script>
  import { isDone, toggle } from '../lib/progress';

  const render = (btn: HTMLElement) => {
    const id = btn.dataset.lessonId!;
    const done = isDone(id);
    btn.setAttribute('aria-pressed', String(done));
    btn.querySelector('.check')!.classList.toggle('hidden', !done);
    (btn.querySelector('.box') as HTMLElement).style.background = done ? 'var(--accent)' : 'transparent';
    (btn.querySelector('.box') as HTMLElement).style.borderColor = done ? 'var(--accent)' : 'var(--border)';
    btn.querySelector('.label')!.textContent = done ? 'Lesson complete' : 'Mark lesson complete';
  };

  document.querySelectorAll<HTMLElement>('.mark-complete').forEach((btn) => {
    render(btn);
    btn.addEventListener('click', () => toggle(btn.dataset.lessonId!));
  });
  document.addEventListener('ctc-progress-change', () =>
    document.querySelectorAll<HTMLElement>('.mark-complete').forEach(render),
  );
</script>
