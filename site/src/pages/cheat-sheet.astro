---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/url';

const shortcuts = await getEntry('reference', '11-shortcuts');
if (!shortcuts) throw new Error('reference entry 11-shortcuts missing');
const { Content } = await render(shortcuts);
---

<Base
  title="Cheat Sheet · Circuit Tracks Companion"
  description="Every Circuit Tracks combo on one printable page, plus the jam-night preflight checklist."
>
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Cheat sheet</h1>
      <p class="mt-2 text-muted max-w-2xl">
        Every combo and power-on gesture, plus the jam preflight and fix-it table.
        Phone-friendly, and printable for the gig bag.
      </p>
    </div>
    <button
      onclick="window.print()"
      class="no-print rounded-lg border border-border px-4 py-2 text-sm font-medium hover:border-accent"
      >Print this</button
    >
  </div>

  <section class="mt-6 rounded-xl border border-border bg-surface p-4 sm:p-6 print:border-0 print:p-0">
    <h2 class="font-semibold text-lg">Jam-night preflight</h2>
    <ol class="mt-2 grid sm:grid-cols-2 gap-x-8 list-decimal pl-5 text-sm leading-6">
      <li>Charged, or USB battery bank packed</li>
      <li>Jam project loaded; scenes ordered by energy</li>
      <li>Tempo &amp; key set — or ready to tap / follow</li>
      <li>Click <strong>off</strong> (it plays on all outputs)</li>
      <li>Filter centred; mutes at home state</li>
      <li><strong>Save Lock on</strong> (power on holding <code>Shift + Save</code>)</li>
      <li>DI box / cables / adapters packed</li>
      <li>Master Volume low → bring up at soundcheck</li>
    </ol>
    <p class="mt-2 text-xs text-muted">
      Mono PA: use L/Mono alone — it auto-sums. Headphones mirror the mains (no separate cue mix).
    </p>
  </section>

  <section class="mt-8 rounded-xl border border-border bg-surface p-4 sm:p-6 print:border-0 print:p-0">
    <h2 class="font-semibold text-lg">When it sounds wrong</h2>
    <div class="mt-2 overflow-x-auto">
      <table class="w-full text-sm border-collapse [&_td]:border [&_td]:border-border [&_td]:px-3 [&_td]:py-1.5 [&_th]:border [&_th]:border-border [&_th]:px-3 [&_th]:py-1.5 [&_th]:bg-surface-2 [&_th]:text-left">
        <thead>
          <tr><th>Symptom</th><th>Fix</th></tr>
        </thead>
        <tbody>
          <tr><td>Muddy</td><td>Dry the low end — pull reverb/delay sends off kick and bass; drop chord roots (the bass owns them); pan mids apart</td></tr>
          <tr><td>Stiff</td><td>Velocity accents + ghost notes; two clicks of swing (needs notes on even steps); a non-quantised recorded pass</td></tr>
          <tr><td>Repetitive</td><td>Probability on decorations (25–50%); Mutate a duplicate; play order (ping-pong/random); an odd pattern length to phase</td></tr>
          <tr><td>Cluttered</td><td>Mute a layer — arrangement is subtraction; leave steps empty; drop a voice from chords; halve a track's sync rate</td></tr>
          <tr><td>Lifeless section</td><td>Ride the filter or unmute into it; octave-up a line; open the hats' decay; automate one send upward</td></tr>
          <tr><td>Loud but small</td><td>Balance levels first (Mixer, everything at 100 = nothing leads); pan for width; side-chain the pads under the kick</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <article class="prose cheat-prose mt-8 max-w-none" data-pagefind-body>
    <Content />
  </article>

  <p class="mt-8 text-sm text-muted no-print">
    Sourced from the <a class="underline" href={withBase('reference/11-shortcuts/')}>shortcuts reference</a> —
    the always-current version.
  </p>
</Base>

<style>
  .cheat-prose :global(table) {
    font-size: 0.82rem;
  }
  @media print {
    :global(section) {
      background: #fff !important;
      color: #000 !important;
      border: 0 !important;
    }
    :global(section .text-muted) {
      color: #444 !important;
    }
    :global(section code) {
      background: #fff !important;
      border-color: #bbb !important;
      color: #000 !important;
    }
    :global(section th) {
      background: #eee !important;
    }
    .cheat-prose :global(a) {
      text-decoration: none;
      color: #000;
    }
    .cheat-prose :global(h2) {
      break-after: avoid;
    }
    .cheat-prose :global(table) {
      break-inside: avoid;
    }
  }
</style>
