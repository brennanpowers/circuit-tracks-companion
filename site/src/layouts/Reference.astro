---
import Base from './Base.astro';
import PanelHighlight from '../components/PanelHighlight.astro';
import { withBase } from '../lib/url';
import { REFERENCE_SECTIONS } from '../data/reference-sections';

interface Props {
  currentId: string;
  title: string;
}
const { currentId, title } = Astro.props;
const idx = REFERENCE_SECTIONS.findIndex((s) => s.id === currentId);
const prev = idx > 0 ? REFERENCE_SECTIONS[idx - 1] : undefined;
const next = idx >= 0 && idx < REFERENCE_SECTIONS.length - 1 ? REFERENCE_SECTIONS[idx + 1] : undefined;
---

<Base title={`${title} · Reference · Circuit Tracks Companion`}>
  <div class="grid lg:grid-cols-[220px_1fr] gap-8">
    <aside class="no-print">
      <details class="lg:open lg:pointer-events-none rounded-lg border border-border lg:border-0 bg-surface lg:bg-transparent" open>
        <summary class="lg:hidden cursor-pointer px-4 py-3 font-semibold">Reference sections</summary>
        <nav aria-label="Reference sections" class="lg:sticky lg:top-20 flex flex-col gap-0.5 p-3 lg:p-0 text-sm">
          <a href={withBase('reference/')} class="px-3 py-1.5 rounded-md text-muted hover:bg-surface-2">↖ Reference home</a>
          {
            REFERENCE_SECTIONS.map((s) => (
              <a
                href={withBase(`reference/${s.id}/`)}
                aria-current={s.id === currentId ? 'page' : undefined}
                class="px-3 py-1.5 rounded-md hover:bg-surface-2 aria-[current=page]:bg-surface-2 aria-[current=page]:text-accent aria-[current=page]:font-medium"
              >
                <span class="text-muted mr-1.5">{s.id.slice(0, 2)}</span>
                {s.title}
              </a>
            ))
          }
        </nav>
      </details>
    </aside>

    <article class="prose min-w-0" data-pagefind-body>
      {
        idx >= 0 && REFERENCE_SECTIONS[idx].controls.length > 0 && (
          <div class="no-print" data-pagefind-ignore>
            <PanelHighlight
              view={REFERENCE_SECTIONS[idx].view}
              controls={[...REFERENCE_SECTIONS[idx].controls]}
              caption={`This section's hardware: where it lives on the device.`}
            />
          </div>
        )
      }
      <slot />
      <nav class="flex justify-between gap-4 mt-12 pt-4 border-t border-border text-sm no-print" aria-label="Section pagination">
        {prev ? <a href={withBase(`reference/${prev.id}/`)}>← {prev.title}</a> : <span />}
        {next ? <a href={withBase(`reference/${next.id}/`)}>{next.title} →</a> : <span />}
      </nav>
    </article>
  </div>
</Base>

<style>
  /* Collapse the guide's trailing Sources block into a quieter appendix */
  article :global(h2#sources) {
    font-size: 0.9rem;
    color: var(--muted);
    border-bottom: 0;
    margin-top: 3rem;
  }
  article :global(h2#sources ~ p) {
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
